  <script>
    // ═════════════════════════════════════════════
    // 動畫 + 音效控制器
    // ═════════════════════════════════════════════
    const stage = document.getElementById('stage');
    const playBtn = document.getElementById('play-btn');
    const muteBtn = document.getElementById('mute-btn');

    let audioCtx = null;
    let master = null;
    let muted = false;
    let loopTimer = null;
    let rollupTimers = [];

    function ensureAudio() {
      if (audioCtx) return;
      audioCtx = new (window.AudioContext || window.webkitAudioContext)();
      master = audioCtx.createGain();
      master.gain.value = 0.5;
      master.connect(audioCtx.destination);
    }

    // ═══ 音效庫 ═══
    function playTone(freq, duration, type = 'sine', volume = 0.3, attack = 0.01) {
      if (!audioCtx || muted) return;
      const osc = audioCtx.createOscillator();
      const g = audioCtx.createGain();
      osc.type = type;
      osc.frequency.value = freq;
      const now = audioCtx.currentTime;
      g.gain.setValueAtTime(0.0001, now);
      g.gain.exponentialRampToValueAtTime(volume, now + attack);
      g.gain.exponentialRampToValueAtTime(0.0001, now + duration);
      osc.connect(g);
      g.connect(master);
      osc.start(now);
      osc.stop(now + duration + 0.05);
    }

    function playChord(freqs, duration, type = 'sine', volume = 0.2) {
      freqs.forEach(f => playTone(f, duration, type, volume));
    }

    // Tap click
    function playTap() {
      playTone(2400, 0.04, 'square', 0.08, 0.001);
    }

    // drone
    let droneOsc = null, droneGain = null;
    function startDrone(freq) {
      stopDrone();
      if (!audioCtx || muted) return;
      droneOsc = audioCtx.createOscillator();
      droneGain = audioCtx.createGain();
      droneOsc.type = 'sine';
      droneOsc.frequency.value = freq;
      droneGain.gain.value = 0;
      droneGain.gain.linearRampToValueAtTime(0.08, audioCtx.currentTime + 0.3);
      droneOsc.connect(droneGain);
      droneGain.connect(master);
      droneOsc.start();
    }
    function stopDrone() {
      if (droneOsc) {
        try {
          droneGain.gain.linearRampToValueAtTime(0, audioCtx.currentTime + 0.2);
          droneOsc.stop(audioCtx.currentTime + 0.25);
        } catch(e) {}
        droneOsc = null;
        droneGain = null;
      }
    }

    // 衝擊音(Latte Factor)
    function playImpact() {
      if (!audioCtx || muted) return;
      const buffer = audioCtx.createBuffer(1, audioCtx.sampleRate * 0.5, audioCtx.sampleRate);
      const data = buffer.getChannelData(0);
      for (let i = 0; i < data.length; i++) {
        data[i] = (Math.random() * 2 - 1) * Math.pow(1 - i / data.length, 1.8);
      }
      const noise = audioCtx.createBufferSource();
      const nG = audioCtx.createGain();
      const filter = audioCtx.createBiquadFilter();
      filter.type = 'lowpass';
      filter.frequency.value = 350;
      noise.buffer = buffer;
      noise.connect(filter);
      filter.connect(nG);
      nG.connect(master);
      nG.gain.setValueAtTime(0.65, audioCtx.currentTime);
      nG.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.45);
      noise.start();
      playTone(48, 0.7, 'sine', 0.5, 0.003);
      playTone(82, 0.5, 'sine', 0.3, 0.003);
    }

    // 勝利揭曉(Scene 2 數字爆出)
    function playReveal() {
      playTone(523.25, 0.4, 'triangle', 0.3, 0.005); // C5
      setTimeout(() => playTone(659.25, 0.4, 'triangle', 0.3, 0.005), 70);  // E5
      setTimeout(() => playTone(783.99, 0.6, 'triangle', 0.35, 0.005), 140); // G5
      setTimeout(() => playTone(1046.5, 0.8, 'sine', 0.25, 0.02), 200); // C6 光
    }

    // 高音 chime(里程碑)
    function playChime() {
      playChord([1046.5, 1318.5, 1568.0], 1.3, 'triangle', 0.22);
      setTimeout(() => playTone(2093, 1.2, 'sine', 0.18, 0.05), 100);
      setTimeout(() => playTone(2637, 1.0, 'sine', 0.14, 0.1), 200);
    }

    // 切頁音 (swoosh)
    function playSwoosh() {
      if (!audioCtx || muted) return;
      const osc = audioCtx.createOscillator();
      const g = audioCtx.createGain();
      osc.type = 'sawtooth';
      osc.frequency.setValueAtTime(200, audioCtx.currentTime);
      osc.frequency.exponentialRampToValueAtTime(800, audioCtx.currentTime + 0.2);
      g.gain.setValueAtTime(0.001, audioCtx.currentTime);
      g.gain.exponentialRampToValueAtTime(0.08, audioCtx.currentTime + 0.05);
      g.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.25);
      osc.connect(g);
      g.connect(master);
      osc.start();
      osc.stop(audioCtx.currentTime + 0.3);
    }

    // ═══ 數字滾動 ═══
    function rollNumber(el, from, to, duration, format) {
      if (!el) return;
      const start = performance.now();
      function step(now) {
        const t = Math.min((now - start) / duration, 1);
        const eased = 1 - Math.pow(1 - t, 3);
        const val = from + (to - from) * eased;
        el.textContent = format(val);
        if (t < 1) requestAnimationFrame(step);
      }
      requestAnimationFrame(step);
    }

    const fmtInt = v => Math.round(v).toLocaleString();
    const fmtDec = d => v => v.toFixed(d);
    const fmtPlusCurr = v => '+NT$ ' + Math.round(v).toLocaleString();

    // ═══ 45 秒音效 + 滾動 排程 ═══
    function runSchedule() {
      // 先清掉舊 timer
      rollupTimers.forEach(t => clearTimeout(t));
      rollupTimers = [];

      const sch = (t, fn) => rollupTimers.push(setTimeout(fn, t));

      // ── SCENE 1 (0-5s) 痛點 · 滴答焦慮 ──
      sch(0,     () => startDrone(58)); // 低頻緊張
      sch(1500,  playTap);
      sch(2800,  playTap);
      sch(3500,  playTap);
      sch(4300,  playTap);

      // ── SCENE 2 (5-10s) 開 app · 揭曉 ⭐ ──
      sch(5000,  () => { stopDrone(); playSwoosh(); }); // 點 app icon
      sch(5500,  () => { startDrone(130); }); // 柔和 drone 接手
      sch(6000,  playReveal); // 今日 +NT$ 3,800 揭曉
      sch(6200,  () => rollNumber(document.getElementById('s2-today-num'), 0, 3800, 1400, fmtPlusCurr));

      // ── SCENE 3 (10-15s) Dashboard 全貌 ──
      sch(10300, () => { stopDrone(); startDrone(164.81); }); // E3
      sch(10400, () => playChord([261.63, 329.63, 392.00], 2.5, 'sine', 0.15));
      sch(10700, () => rollNumber(document.getElementById('s3-net-num'), 0, 3320000, 1700, fmtInt));
      sch(12500, () => playTone(523.25, 0.4, 'triangle', 0.2));

      // ── SCENE 4 (15-22s) Latte Factor ⭐⭐ ──
      sch(15100, () => { stopDrone(); startDrone(73.42); }); // D2 陰暗
      sch(15400, playSwoosh);
      sch(17200, () => playTone(1000, 0.05, 'square', 0.1)); // tap coffee
      sch(17800, () => playTone(1500, 0.06, 'square', 0.1));
      sch(18400, () => playTone(1500, 0.06, 'square', 0.12));
      sch(19000, () => playTone(1500, 0.06, 'square', 0.12));
      sch(19300, () => playImpact());
      sch(19400, () => rollNumber(document.getElementById('s4-money-num'), 0, 180000, 1300, fmtInt));
      sch(19700, () => playTone(82, 1.8, 'sine', 0.3, 0.02)); // 殘響

      // ── SCENE 5 (22-28s) Goal Engine ──
      sch(22000, () => { stopDrone(); startDrone(146.83); }); // D3 希望
      sch(22200, playSwoosh);
      sch(22700, () => rollNumber(document.getElementById('s5-years-num'), 99.9, 9.4, 1500, fmtDec(1)));
      sch(22500, () => playChord([293.66, 369.99, 440.00], 2.5, 'sine', 0.18)); // D F# A
      sch(25500, () => playChord([392.00, 493.88, 587.33], 1.8, 'triangle', 0.22)); // G B D
      sch(26500, () => playTone(1174.66, 0.8, 'sine', 0.2)); // 到頂 chime

      // ── SCENE 6 (28-35s) 個股洞察 ──
      sch(28000, () => { stopDrone(); startDrone(130.81); }); // C3
      sch(28200, playSwoosh);
      sch(29000, () => rollNumber(document.getElementById('s6-stock-price'), 0, 1900, 1100, fmtInt));
      sch(29300, () => rollNumber(document.getElementById('s6-holding-val'), 0, 950000, 1300, fmtInt));
      sch(29800, () => rollNumber(document.getElementById('s6-holding-today'), 0, 11000, 1200, fmtInt));
      sch(30000, () => playTone(523, 0.3, 'sine', 0.15));
      sch(31500, () => playTone(800, 0.3, 'sine', 0.18)); // 雷達完成
      sch(32000, playImpact); // 警示

      // ── SCENE 7 (35-40s) 里程碑 ──
      sch(35000, () => { stopDrone(); playChime(); });
      sch(35300, playTone.bind(null, 2093, 1.0, 'sine', 0.2, 0.02));
      sch(37000, () => playChord([523.25, 659.25, 783.99], 1.8, 'triangle', 0.2));

      // ── SCENE 8 (40-45s) 品牌 CTA ──
      sch(40000, playSwoosh);
      sch(40500, () => playChord([261.63, 329.63, 392.00, 523.25], 4.2, 'sine', 0.22)); // C E G C
      sch(42500, () => playTone(1046.5, 1.8, 'sine', 0.16, 0.05));
      sch(43500, () => playTone(1568.0, 1.3, 'sine', 0.13, 0.08));
      sch(45000, () => stopDrone());
    }

    function startAll() {
      ensureAudio();
      if (audioCtx.state === 'suspended') audioCtx.resume();

      stage.classList.remove('playing');
      void stage.offsetWidth;
      stage.classList.add('playing');

      if (loopTimer) clearInterval(loopTimer);
      stopDrone();
      runSchedule();
      loopTimer = setInterval(() => {
        stopDrone();
        runSchedule();
      }, 45000);
    }

    playBtn.addEventListener('click', () => {
      startAll();
      playBtn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M6 6h12v12H6z"/></svg>重新播放';
    });

    muteBtn.addEventListener('click', () => {
      muted = !muted;
      if (master) master.gain.value = muted ? 0 : 0.5;
      muteBtn.textContent = muted ? '🔊 取消靜音' : '🔇 靜音';
      if (muted) stopDrone();
    });
  </script>
