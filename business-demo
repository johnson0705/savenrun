<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>資產地圖 · 45 秒 · Final Cut</title>
<style>
  :root {
    --bg-app: #0D1117;
    --bg-card: #161B22;
    --bg-elevated: #21262D;
    --brand-primary: #3B82F6;
    --brand-secondary: #60A5FA;
    --brand-gold: #FFD600;
    --profit: #10B981;
    --profit-strong: #34D399;
    --loss: #EF4444;
    --loss-strong: #F87171;
    --warn: #F59E0B;
    --warn-strong: #FBBF24;
    --violet: #A78BFA;
    --text-primary: #F0F6FC;
    --text-secondary: #8B949E;
    --text-tertiary: #484F58;
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  html, body {
    background: radial-gradient(circle at 50% 50%, #111 0%, #000 100%);
    font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Noto Sans TC', 'PingFang TC', sans-serif;
    color: var(--text-primary);
    -webkit-font-smoothing: antialiased;
    overflow: hidden;
    width: 100%; height: 100%;
  }
  body {
    min-height: 100vh;
    display: flex; align-items: center; justify-content: center;
    padding: 16px;
  }

  /* ═════════════ 外層 ═════════════ */
  .stage-wrap {
    display: flex; flex-direction: column;
    align-items: center; gap: 16px;
  }

  /* ═════════════ iPhone 框 ═════════════ */
  .phone {
    position: relative;
    width: 340px; height: 696px;
    background: linear-gradient(135deg, #2A2F3A 0%, #1A1D24 100%);
    border-radius: 44px;
    padding: 10px;
    box-shadow:
      0 50px 100px rgba(0,0,0,0.8),
      inset 0 0 0 1.5px rgba(255,255,255,0.08),
      inset 0 2px 6px rgba(255,255,255,0.06);
  }
  .notch {
    position: absolute;
    top: 18px; left: 50%; transform: translateX(-50%);
    width: 100px; height: 24px;
    background: #000;
    border-radius: 999px;
    z-index: 50;
    display: flex; align-items: center; justify-content: flex-end;
    padding-right: 10px;
    gap: 4px;
  }
  .notch .cam {
    width: 8px; height: 8px; border-radius: 50%;
    background: #1a1a1a;
    box-shadow: inset 0 0 0 1px rgba(255,255,255,0.1);
  }
  .screen {
    position: relative;
    width: 100%; height: 100%;
    background: var(--bg-app);
    border-radius: 34px;
    overflow: hidden;
  }

  /* 狀態列 (統一頂端) */
  .status-bar {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 44px;
    display: flex; align-items: flex-end;
    justify-content: space-between;
    padding: 0 24px 6px;
    font-size: 11px; font-weight: 700;
    color: var(--text-primary);
    z-index: 40;
    pointer-events: none;
  }
  .status-bar .time { font-variant-numeric: tabular-nums; }
  .status-bar .sys {
    display: flex; gap: 4px; align-items: center;
  }
  .status-bar svg { display: block; }

  /* ═════════════ Scene 包裹 ═════════════ */
  .scene {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    opacity: 0;
    pointer-events: none;
  }

  /* 45s 主時間軸分配
     S1  0–5s   (0%–11.1%)      痛點
     S2  5–10s  (11.1–22.2%)    開 app + 今日損益
     S3  10–15s (22.2–33.3%)    Dashboard 全貌
     S4  15–22s (33.3–48.9%)    Latte Factor ⭐
     S5  22–28s (48.9–62.2%)    Goal Engine
     S6  28–35s (62.2–77.8%)    個股深度洞察
     S7  35–40s (77.8–88.9%)    里程碑
     S8  40–45s (88.9–100%)     品牌 CTA
     每場景 crossfade 重疊 1% (0.45s),避免死幀
  */
  .stage.playing .scene-1 { animation: s1-show 45s linear infinite; }
  .stage.playing .scene-2 { animation: s2-show 45s linear infinite; }
  .stage.playing .scene-3 { animation: s3-show 45s linear infinite; }
  .stage.playing .scene-4 { animation: s4-show 45s linear infinite; }
  .stage.playing .scene-5 { animation: s5-show 45s linear infinite; }
  .stage.playing .scene-6 { animation: s6-show 45s linear infinite; }
  .stage.playing .scene-7 { animation: s7-show 45s linear infinite; }
  .stage.playing .scene-8 { animation: s8-show 45s linear infinite; }

  @keyframes s1-show { 0% {opacity:0;} 0.5%,10% {opacity:1;} 11.5%,100% {opacity:0;} }
  @keyframes s2-show { 0%,10% {opacity:0;} 11%,21% {opacity:1;} 22.5%,100% {opacity:0;} }
  @keyframes s3-show { 0%,21% {opacity:0;} 22%,32% {opacity:1;} 33.5%,100% {opacity:0;} }
  @keyframes s4-show { 0%,32% {opacity:0;} 33%,48% {opacity:1;} 49.5%,100% {opacity:0;} }
  @keyframes s5-show { 0%,48% {opacity:0;} 49%,61% {opacity:1;} 62.5%,100% {opacity:0;} }
  @keyframes s6-show { 0%,61% {opacity:0;} 62%,77% {opacity:1;} 78.5%,100% {opacity:0;} }
  @keyframes s7-show { 0%,77% {opacity:0;} 78%,88% {opacity:1;} 89.5%,100% {opacity:0;} }
  @keyframes s8-show { 0%,88% {opacity:0;} 89%,99% {opacity:1;} 100% {opacity:0;} }

  /* ═════════════ 共用手指指標 ═════════════ */
  .finger {
    position: absolute;
    width: 26px; height: 26px; border-radius: 50%;
    background: rgba(255,255,255,0.25);
    border: 2px solid rgba(255,255,255,0.9);
    pointer-events: none;
    z-index: 90;
    box-shadow: 0 0 20px rgba(255,255,255,0.4);
    opacity: 0;
  }
  .finger::after {
    content: ''; position: absolute; inset: -2px;
    border-radius: 50%;
    border: 2px solid rgba(255,255,255,0.6);
  }

  /* ═════════════ 底部 Tab bar (S2–S6 使用) ═════════════ */
  .tab-bar {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 60px;
    background: rgba(22,27,34,0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-top: 1px solid rgba(255,255,255,0.06);
    display: flex; align-items: center;
    padding: 0 16px 14px;
    gap: 0;
    z-index: 30;
  }
  .tab {
    flex: 1;
    display: flex; flex-direction: column;
    align-items: center; gap: 3px;
    color: var(--text-tertiary);
    font-size: 9px; font-weight: 700;
    letter-spacing: 0.06em;
  }
  .tab.active { color: var(--brand-secondary); }
  .tab svg { width: 20px; height: 20px; }

  /* ═════════════ ACT 1 · 痛點混亂 ═════════════ */

  .s1-home {
    position: absolute; inset: 0;
    padding: 50px 20px 0;
    background: linear-gradient(180deg, #1A2438 0%, #0F1624 100%);
  }

  .s1-title {
    text-align: center;
    font-size: 11px; font-weight: 700;
    color: rgba(255,255,255,0.55);
    margin-bottom: 14px;
    letter-spacing: 0.12em;
  }
  .s1-apps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px 10px;
    margin-bottom: 30px;
  }
  .s1-app {
    display: flex; flex-direction: column;
    align-items: center; gap: 4px;
    color: rgba(255,255,255,0.75);
    font-size: 9px; font-weight: 600;
  }
  .s1-app .icon {
    width: 52px; height: 52px;
    border-radius: 13px;
    display: flex; align-items: center; justify-content: center;
    font-size: 24px;
  }
  .s1-app.stock .icon { background: linear-gradient(135deg, #3B82F6, #1D4ED8); }
  .s1-app.bank .icon  { background: linear-gradient(135deg, #10B981, #047857); }
  .s1-app.us .icon    { background: linear-gradient(135deg, #EF4444, #B91C1C); }
  .s1-app.excel .icon { background: linear-gradient(135deg, #22C55E, #15803D); }
  .s1-app.crypto .icon{ background: linear-gradient(135deg, #F59E0B, #D97706); }
  .s1-app.notes .icon { background: linear-gradient(135deg, #FBBF24, #F59E0B); }
  .s1-app.calc .icon  { background: linear-gradient(135deg, #64748B, #334155); }
  .s1-app.chat .icon  { background: linear-gradient(135deg, #8B5CF6, #6D28D9); }

  /* 多個資產快閃覆蓋層 */
  .s1-flash {
    position: absolute;
    inset: 0;
    opacity: 0;
    background: var(--bg-card);
    display: flex; flex-direction: column;
    padding: 48px 20px;
    z-index: 20;
  }
  .s1-flash .flash-title {
    font-size: 13px; font-weight: 800;
    color: var(--text-primary);
    margin-bottom: 16px;
  }
  .s1-flash .flash-items {
    display: flex; flex-direction: column; gap: 10px;
  }
  .s1-flash .item {
    display: flex; justify-content: space-between;
    padding: 12px 14px;
    background: rgba(255,255,255,0.04);
    border-radius: 10px;
    font-size: 12px; font-weight: 700;
  }
  .s1-flash .item .sym { color: var(--text-secondary); }
  .s1-flash .item .val { font-variant-numeric: tabular-nums; }
  .s1-flash .item .val.up { color: var(--profit-strong); }
  .s1-flash .item .val.dn { color: var(--loss-strong); }

  .stage.playing .s1-flash { animation-duration: 45s; animation-iteration-count: infinite; }
  .s1-flash.app-stock { animation-name: s1-f1; }
  .s1-flash.app-bank  { animation-name: s1-f2; background: linear-gradient(180deg, #082B1F, #04160F); }
  .s1-flash.app-us    { animation-name: s1-f3; background: linear-gradient(180deg, #2B0808, #160404); }
  .s1-flash.app-crypto{ animation-name: s1-f4; background: linear-gradient(180deg, #2B1C08, #160E04); }

  @keyframes s1-f1 {
    0%,2% { opacity: 0; transform: translateX(30%); }
    3%,4.5% { opacity: 1; transform: translateX(0); }
    5%,100% { opacity: 0; transform: translateX(-30%); }
  }
  @keyframes s1-f2 {
    0%,4.5% { opacity: 0; transform: translateX(30%); }
    5.5%,6.5% { opacity: 1; transform: translateX(0); }
    7%,100% { opacity: 0; transform: translateX(-30%); }
  }
  @keyframes s1-f3 {
    0%,6.5% { opacity: 0; transform: translateX(30%); }
    7.5%,8% { opacity: 1; transform: translateX(0); }
    8.5%,100% { opacity: 0; transform: translateX(-30%); }
  }
  @keyframes s1-f4 {
    0%,8% { opacity: 0; transform: translateX(30%); }
    9%,9.5% { opacity: 1; transform: translateX(0); }
    10%,100% { opacity: 0; transform: translateX(-30%); }
  }

  /* 最後定格問號 */
  .s1-question {
    position: absolute;
    inset: 0;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    background: rgba(13,17,23,0.88);
    backdrop-filter: blur(8px);
    opacity: 0;
    z-index: 30;
    text-align: center;
    padding: 20px;
  }
  .stage.playing .s1-question { animation: s1-q 45s infinite; }
  @keyframes s1-q {
    0%,9.5% { opacity: 0; backdrop-filter: blur(0); }
    10.2%,10.5% { opacity: 1; backdrop-filter: blur(8px); }
    11.2%,100% { opacity: 0; }
  }
  .s1-question .small {
    font-size: 13px; color: var(--text-secondary);
    font-weight: 700; letter-spacing: 0.08em;
    margin-bottom: 8px;
  }
  .s1-question .big {
    font-size: 24px; font-weight: 900;
    line-height: 1.3;
    letter-spacing: -0.02em;
  }
  .s1-question .toggle-g {
    display: inline-block;
    padding: 2px 10px; border-radius: 8px;
    background: rgba(16,185,129,0.2);
    color: var(--profit-strong);
    animation: s1-flash-g 0.5s infinite;
  }
  .s1-question .toggle-r {
    display: inline-block;
    padding: 2px 10px; border-radius: 8px;
    background: rgba(239,68,68,0.2);
    color: var(--loss-strong);
    animation: s1-flash-r 0.5s infinite;
  }
  @keyframes s1-flash-g { 0%,100% { filter: brightness(1); } 50% { filter: brightness(1.5); } }
  @keyframes s1-flash-r { 0%,100% { filter: brightness(1); } 50% { filter: brightness(1.5); } }

  /* Finger tap points in S1 */
  .s1-finger {
    position: absolute;
    z-index: 80;
    width: 24px; height: 24px;
    border-radius: 50%;
    background: rgba(255,255,255,0.3);
    border: 2px solid rgba(255,255,255,0.9);
    opacity: 0;
  }
  .stage.playing .s1-finger { animation-duration: 45s; animation-iteration-count: infinite; }
  .s1-finger.f1 { animation-name: s1-finger-1; top: 98px; left: 38px; }
  .s1-finger.f2 { animation-name: s1-finger-2; top: 98px; left: 113px; }
  .s1-finger.f3 { animation-name: s1-finger-3; top: 98px; left: 188px; }
  .s1-finger.f4 { animation-name: s1-finger-4; top: 170px; left: 38px; }

  @keyframes s1-finger-1 {
    0%,1% { opacity: 0; transform: scale(1.4); }
    2%,3% { opacity: 0.9; transform: scale(1); }
    3.5%,4% { opacity: 0; transform: scale(1.6); }
    5%,100% { opacity: 0; }
  }
  @keyframes s1-finger-2 {
    0%,3.5% { opacity: 0; transform: scale(1.4); }
    4.5%,5.5% { opacity: 0.9; transform: scale(1); }
    6%,6.5% { opacity: 0; transform: scale(1.6); }
    7%,100% { opacity: 0; }
  }
  @keyframes s1-finger-3 {
    0%,6% { opacity: 0; transform: scale(1.4); }
    7%,7.8% { opacity: 0.9; transform: scale(1); }
    8.2%,8.5% { opacity: 0; transform: scale(1.6); }
    9%,100% { opacity: 0; }
  }
  @keyframes s1-finger-4 {
    0%,8.3% { opacity: 0; transform: scale(1.4); }
    9%,9.5% { opacity: 0.9; transform: scale(1); }
    10%,10.2% { opacity: 0; transform: scale(1.6); }
    11%,100% { opacity: 0; }
  }

  /* ═════════════ ACT 2 · 開 app 即刻見答 ═════════════ */

  .s2-home {
    position: absolute; inset: 0;
    padding: 50px 20px 0;
    background: linear-gradient(180deg, #1A2438 0%, #0F1624 100%);
    opacity: 0;
  }
  .stage.playing .s2-home { animation: s2-home 45s infinite; }
  @keyframes s2-home {
    0%,11% { opacity: 0; }
    11.2%,12% { opacity: 1; }
    12.8%,100% { opacity: 0; }
  }
  .s2-home-title {
    text-align: center;
    font-size: 11px; font-weight: 700;
    color: rgba(255,255,255,0.55);
    margin-bottom: 14px;
    letter-spacing: 0.12em;
  }
  .s2-apps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px 10px;
  }
  .s2-app-icon {
    display: flex; flex-direction: column;
    align-items: center; gap: 4px;
    color: rgba(255,255,255,0.75);
    font-size: 9px; font-weight: 600;
  }
  .s2-app-icon .icon {
    width: 52px; height: 52px;
    border-radius: 13px;
    display: flex; align-items: center; justify-content: center;
    font-size: 22px; font-weight: 900;
  }

  .s2-map-icon {
    background: linear-gradient(135deg, var(--brand-primary) 0%, var(--brand-gold) 100%);
    color: #0D1117;
    position: relative;
  }
  .stage.playing .s2-map-icon { animation: s2-icon-highlight 45s infinite; }
  @keyframes s2-icon-highlight {
    0%,11.5% { box-shadow: none; }
    12%,12.5% { box-shadow: 0 0 0 4px rgba(255,214,0,0.5); transform: scale(1.05); }
    13%,14% { box-shadow: none; transform: scale(0.8); opacity: 0.5; }
    14.5%,100% { opacity: 0; transform: scale(0); }
  }

  /* Finger 點 map icon */
  .s2-finger {
    position: absolute;
    top: 112px; left: 188px;
    width: 28px; height: 28px;
    border-radius: 50%;
    background: rgba(255,255,255,0.3);
    border: 2.5px solid rgba(255,255,255,0.95);
    box-shadow: 0 0 20px rgba(255,255,255,0.5);
    opacity: 0;
    z-index: 60;
  }
  .stage.playing .s2-finger { animation: s2-finger 45s infinite; }
  @keyframes s2-finger {
    0%,11% { opacity: 0; transform: scale(1.5); }
    11.5%,12% { opacity: 1; transform: scale(1); }
    12.5%,12.8% { opacity: 0; transform: scale(1.8); }
    13%,100% { opacity: 0; }
  }

  /* Dashboard 進場 */
  .s2-dashboard {
    position: absolute; inset: 0;
    background: var(--bg-app);
    transform: scale(0);
    border-radius: 60% 60% 0 0;
    opacity: 0;
    padding: 44px 16px 60px;
    overflow: hidden;
  }
  .stage.playing .s2-dashboard { animation: s2-dash 45s infinite; }
  @keyframes s2-dash {
    0%,12.5% { opacity: 0; transform: scale(0); border-radius: 60% 60% 0 0; }
    13%,14% { opacity: 1; transform: scale(1.05); border-radius: 30% 30% 0 0; }
    14.5%,21% { opacity: 1; transform: scale(1); border-radius: 0; }
    22%,100% { opacity: 0; }
  }

  .s2-greeting {
    font-size: 13px; font-weight: 700;
    color: var(--text-secondary);
    margin-bottom: 4px;
    opacity: 0;
  }
  .stage.playing .s2-greeting { animation: s2-fade 45s infinite; }
  @keyframes s2-fade {
    0%,13% { opacity: 0; }
    14%,21% { opacity: 1; }
    22%,100% { opacity: 0; }
  }

  .s2-today-card {
    position: relative;
    background: linear-gradient(145deg, #0F3828 0%, #0A2518 100%);
    border: 1px solid rgba(16,185,129,0.4);
    border-radius: 18px;
    padding: 20px;
    margin-bottom: 14px;
    overflow: hidden;
    opacity: 0;
  }
  .stage.playing .s2-today-card { animation: s2-today 45s infinite; }
  @keyframes s2-today {
    0%,13.2% { opacity: 0; transform: translateY(20px); }
    14%,20.5% { opacity: 1; transform: translateY(0); }
    22%,100% { opacity: 0; }
  }
  .s2-today-card::before {
    content: ''; position: absolute;
    top: -40px; right: -40px;
    width: 140px; height: 140px;
    background: radial-gradient(circle, rgba(16,185,129,0.25) 0%, transparent 70%);
    border-radius: 50%;
  }
  .s2-today-label {
    position: relative;
    font-size: 12px; font-weight: 700;
    color: rgba(255,255,255,0.7);
    letter-spacing: 0.05em;
    margin-bottom: 8px;
  }
  .s2-today-num {
    position: relative;
    font-size: 36px; font-weight: 900;
    color: var(--profit-strong);
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.03em;
    line-height: 1;
    text-shadow: 0 0 30px rgba(16,185,129,0.5);
  }
  .s2-today-pct {
    position: relative;
    display: inline-block;
    margin-top: 8px;
    padding: 4px 10px;
    background: rgba(16,185,129,0.2);
    color: var(--profit-strong);
    border-radius: 9999px;
    font-size: 12px; font-weight: 800;
    font-variant-numeric: tabular-nums;
  }

  /* 光暈脈動 */
  .s2-pulse {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 100px; height: 100px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(16,185,129,0.3) 0%, transparent 70%);
    pointer-events: none;
    opacity: 0;
  }
  .stage.playing .s2-pulse { animation: s2-pulse 45s infinite; }
  @keyframes s2-pulse {
    0%,13.5% { opacity: 0; transform: translate(-50%, -50%) scale(0.3); }
    14%,14.5% { opacity: 1; transform: translate(-50%, -50%) scale(1); }
    15%,16% { opacity: 0; transform: translate(-50%, -50%) scale(2); }
    17%,100% { opacity: 0; }
  }

  /* 小小資產預覽卡 */
  .s2-preview-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
    margin-bottom: 14px;
    opacity: 0;
  }
  .stage.playing .s2-preview-row { animation: s2-preview 45s infinite; }
  @keyframes s2-preview {
    0%,15% { opacity: 0; transform: translateY(14px); }
    16%,20.5% { opacity: 1; transform: translateY(0); }
    22%,100% { opacity: 0; }
  }
  .s2-preview-card {
    background: var(--bg-card);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 12px;
    padding: 10px;
    font-size: 9px;
  }
  .s2-preview-card .lbl { color: var(--text-secondary); font-weight: 600; margin-bottom: 2px; }
  .s2-preview-card .val {
    font-size: 13px; font-weight: 800;
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.01em;
  }
  .s2-preview-card .chg { font-size: 9px; font-weight: 700; font-variant-numeric: tabular-nums; }
  .chg-up { color: var(--profit-strong); }
  .chg-dn { color: var(--loss-strong); }

  .s2-hint {
    text-align: center;
    font-size: 11px; color: var(--text-secondary);
    font-weight: 600;
    opacity: 0;
  }
  .stage.playing .s2-hint { animation: s2-hint 45s infinite; }
  @keyframes s2-hint {
    0%,17% { opacity: 0; }
    18%,20.5% { opacity: 1; }
    22%,100% { opacity: 0; }
  }
  .s2-hint b { color: var(--text-primary); font-weight: 900; }

  /* Tab bar 只在 S2-S7 顯示 */
  .scene-2 .tab-bar, .scene-3 .tab-bar, .scene-4 .tab-bar,
