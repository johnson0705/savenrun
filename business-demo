  @keyframes p3 { 0%,80% { opacity: 0; transform: translate(-50%, -50%); } 81%,81.5% { opacity: 1; transform: translate(-50%, -50%); } 83%,84% { opacity: 0; transform: translate(-400%, 200%); } 89%,100% { opacity: 0; } }
